# URL absoluta del API (desarrollo con backend en localhost:3000):
VITE_API_URL=http://localhost:3000/api/v1
#
# Opcional para Vite sin CORS explícitos: comente línea anterior y usará proxy de vite.config.ts
# (entonces omita esta variable para que el cliente use rutas relativas `/api/v1`).
VITE_SOCKET_URL=http://localhost:3000

# Google Analytics 4
VITE_GA_MEASUREMENT_ID="G-2Z3G5CCJWX"
VITE_GA_ENABLED=false
VITE_GA_DEBUG=false

# Producción (ProfeConnect) — copie a .env o configure en el hosting
SOCKET_URL="https://profeconnect-backend.up.railway.app/chatbot"
API_URL="https://profeconnect-backend.up.railway.app/api/v1"
# Vite usa prefijo VITE_; SOCKET_URL es la base SIN /chatbot (socket.ts añade /chatbot)
# VITE_API_URL=https://profeconnect-backend.up.railway.app/api/v1
# VITE_SOCKET_URL=https://profeconnect-backend.up.railway.app

# Base de datos (usado por docker-compose.yml)
POSTGRES_USER=amigo
POSTGRES_PASSWORD=amigo_dev
POSTGRES_DB=amigojolive

# URLs para el backend (.env del backend)
# DIRECT_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"
# DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"
