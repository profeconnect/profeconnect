// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVO
  INACTIVO
  PENDIENTE
  BLOQUEADO
}

enum RegistrationRequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  active      Boolean  @default(true)

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id                 Int        @id @default(autoincrement())
  institutionalEmail String     @unique
  passwordHash       String
  firstName          String
  lastName           String
  status             UserStatus @default(ACTIVO)

  roleId             Int
  role               Role       @relation(fields: [roleId], references: [id])

  teacherProfile     TeacherProfile?

  posts              Post[]
  comments           Comment[]

  reviewedRegistrationRequests RegistrationRequest[] @relation("ReviewedRegistrationRequests")
  securityIncidents  SecurityIncident[]

  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("usuarios")
}

model TeacherProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])

  area        String?
  description String?
  photoUrl    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("perfiles_docente")
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  isAnonymous Boolean  @default(false)
  status      PostStatus @default(PUBLISHED)
  deletedAt   DateTime?

  authorId    Int
  author      User @relation(fields: [authorId], references: [id])
  comments    Comment[]
  tags        Tag[]

  attachments PostAttachment[]
  securityIncidents SecurityIncident[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("publicaciones")
}

model PostAttachment {
  id          Int @id @default(autoincrement())
  filename    String
  originalName String
  mimeType    String
  path        String
  size        Int
  type        AttachmentType
  postId      Int
  post        Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  isSuspicious Boolean @default(false)

  createdAt   DateTime @default(now())

  @@map("adjuntos_publicacion")
}

enum AttachmentType {
  IMAGE
  DOCUMENT
}

enum PostStatus {
  PUBLISHED
  ARCHIVED
  HIDDEN
}

model Comment {
  id          Int      @id @default(autoincrement())
  content     String   @db.Text
  isAnonymous Boolean  @default(false) // Para aplicar anonimato en los comentarios si el usuario lo desea

  // Relación con el Post al que pertenece
  postId      Int
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Relación con el Usuario que comenta
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("comentarios")
}

model Tag {
  id          Int      @id @default(autoincrement())
  name        String   @unique // Las diferentes etiquetas, que todavia esta por definir
  posts       Post[]   // Relación Muchos a Muchos para etiquetar los post

  @@map("etiquetas")
}

model RegistrationRequest {
  id                 Int                       @id @default(autoincrement())
  institutionalEmail String
  passwordHash       String?
  firstName          String
  lastName           String
  area               String?
  description        String?

  status             RegistrationRequestStatus @default(PENDIENTE)

  reviewedById       Int?
  reviewedBy         User?                     @relation("ReviewedRegistrationRequests", fields: [reviewedById], references: [id])

  reviewComment      String?
  reviewedAt         DateTime?

  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([institutionalEmail])
  @@index([status])

  @@map("solicitudes_registro")
}

model SecurityIncident {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  fileName      String
  attemptedMime String
  detectedMime  String
  status        String   @default("PENDING") // PENDING, RESOLVED
  physicalPath  String?
  postId        Int?
  post          Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileMetadata  Json?
  createdAt     DateTime @default(now())

  @@map("incidentes_seguridad")
}