# Copie este archivo a .env y rellene con sus credenciales reales.
# No suba .env al repositorio.

# ─── Base de datos ────────────────────────────────────────────────────────────
# Pooler sesión/directo (puerto 5432) — mismo valor que usará el servidor en desarrollo típico.
# Ejemplo Supabase: postgresql://postgres.xxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Usado por `prisma migrate` y `prisma generate` (CLI). En local conviene igualar DIRECT_URL si solo hay una base.
# Pooler transaccional (Supabase puerto 6543) cuando aplique:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres"

# Sobrescrito solo cuando DIRECT_URL/TIMEouts en cloud; valores placeholder (p. ej. postgresql://ruta) se ignoran automáticamente.
# Déjelo vacío en la mayoría de los casos.
DATABASE_APP_URL=""

# ─── PostgreSQL local (Docker) ────────────────────────────────────────────────
# En la raíz del monorepo: docker compose up -d postgres
# Luego puede usar estas líneas (y comentar o borrar los placeholders USER:PASSWORD):
# DIRECT_URL="postgresql://amigo:amigo_dev@localhost:5432/amigojolive"
# DATABASE_URL="postgresql://amigo:amigo_dev@localhost:5432/amigojolive"
# Ejecutar: npm run prisma:deploy --prefix backend ; npm run db:seed --prefix backend


# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="cambie-esta-clave-por-una-segura"
JWT_EXPIRES_IN="1d"

# ─── Seed (admin inicial) ─────────────────────────────────────────────────────
ADMIN_EMAIL="admin@institucion.edu.ec"
ADMIN_PASSWORD="Admin123456"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL="http://localhost:5173"
APP_PUBLIC_URL="http://localhost:5173"
# Producción Railway → actualice en el panel de Railway, no aquí:
# FRONTEND_URL="https://profeconnect.up.railway.app"

# ─── Chatbot (OpenAI compatible) ──────────────────────────────────────────────
CHATBOT_API_KEY=""

# Correos transaccionales (Gmail SMTP)
# La contrasena de aplicacion solo va en backend/Railway. Nunca en frontend.
GMAIL_USER="profeconnect69@gmail.com"
GMAIL_APP_PASSWORD=""
EMAIL_FROM_NAME="ProfeConnect"
# En Railway use false para enviar al destinatario real.
EMAIL_TEST_MODE=true
EMAIL_TEST_TO_EMAIL="profeconnect69@gmail.com"
ALLOWED_INSTITUTIONAL_DOMAINS="educacion.gob.ec"
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=24

# Supabase Storage
# Use la service role key solo en backend/Railway. Nunca la exponga en frontend.
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PUBLIC_BUCKET="publication-files"
SUPABASE_PRIVATE_BUCKET="private-files"
