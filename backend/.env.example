# Copie a .env y rellene con sus credenciales (no suba .env al repositorio).

# Pooler transaccional (Supabase, puerto 6543) — útil para serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres"

# Pooler sesión / directo (puerto 5432) — recomendado para este backend Node + Prisma adapter
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Si sigue habiendo timeouts, pegue aquí la URI "Direct connection" del panel Supabase (host db.*.supabase.co)
DATABASE_APP_URL="postgresql://ruta"

JWT_SECRET="cambie-esta-clave"
JWT_EXPIRES_IN="1d"

ADMIN_EMAIL="admin@institucion.edu.ec"
ADMIN_PASSWORD="Admin123456"

PORT=3000

CHATBOT_API_KEY="que-te-importa-sapo"
FRONTEND_URL="http://localhost:5173"
